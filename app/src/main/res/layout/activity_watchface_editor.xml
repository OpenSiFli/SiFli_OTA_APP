<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".modules.debug.guibuilder.WatchfaceEditorActivity">

    <com.sifli.sifliapp.utils.SFScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="[GUI Builder SDK]Mac" />

                <TextView
                    android:id="@+id/sf_guibuilder_mac_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="---" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="5dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/sf_guibuilder_select_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_margin="5dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="SELECT FILE"
                    android:textSize="13sp"
                    tools:ignore="TouchTargetSizeCheck" />

                <TextView
                    android:id="@+id/sf_guibuilder_filename_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="---" />
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <TextView
                    android:id="@+id/textView12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:text="操作"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/sf_guibuilder_load_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_margin="5dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="Load"
                    android:textSize="13sp"
                    tools:ignore="TouchTargetSizeCheck" />

                <Button
                    android:id="@+id/sf_guibuilder_preview_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_margin="10dp"
                    android:minWidth="0dp"

                    android:minHeight="0dp"
                    android:text="Preview"
                    android:textSize="13sp"
                    tools:ignore="TouchTargetSizeCheck" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="5dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:visibility="invisible"
                    android:text="操作"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/sf_guibuilder_language_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="5dp"
                    android:minWidth="0dp"

                    android:minHeight="0dp"
                    android:text="Language"
                    android:textSize="13sp"
                    tools:ignore="TouchTargetSizeCheck" />
                <Button
                    android:id="@+id/sf_guibuilder_theme_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="Theme"
                    android:textSize="13sp"
                    tools:ignore="TouchTargetSizeCheck" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/sf_guibuilder_preview_iv"
                    android:layout_width="250dp"
                    android:layout_height="250dp"
                    android:layout_gravity="center_horizontal"
                    android:background="#ebebeb"
                    android:scaleType="fitCenter" />
            </LinearLayout>
            <com.sifli.sifliapp.utils.WrapContentListView
                android:id="@+id/sf_guibuilder_edit_lv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#f5f5f5">

            </com.sifli.sifliapp.utils.WrapContentListView>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:orientation="vertical">

                <com.sifli.sifliapp.utils.SFScrollView
                    android:id="@+id/sf_guibuilder_log_sv"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/black"
                    android:scrollbars="vertical">

                    <TextView
                        android:id="@+id/sf_guibuilder_log_tv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="0dp"
                        android:background="@color/black"
                        android:gravity="start|bottom"
                        android:lineSpacingExtra="5dp"
                        android:scrollbars="none"
                        android:text="--log--"
                        android:textColor="@color/white"
                        android:textIsSelectable="true"
                        android:textSize="10sp" />
                </com.sifli.sifliapp.utils.SFScrollView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="05dp">

                <TextView
                    android:id="@+id/sf_guibuilder_progress_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="进度"
                    android:textSize="12sp" />

                <ProgressBar
                    android:id="@+id/sf_guibuilder_progress_pb"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="15dp"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginTop="5dp"
                    android:max="100"
                    android:min="0"
                    android:progress="00" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="05dp">

                <TextView

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="速度"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/sf_guibuilder_speed_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:text="瞬时 0 KB/s 平均 0 KB/s"
                    android:textSize="12sp" />


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:text="操作"
                    android:textSize="10sp" />

                <Button
                    android:id="@+id/sf_guibuilder_delete_app_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_margin="10dp"
                    android:minWidth="0dp"

                    android:minHeight="0dp"
                    android:text="DELETE APP"
                    android:textColor="#ff9999"
                    android:textSize="13sp"
                    tools:ignore="TouchTargetSizeCheck" />

                <Button
                    android:id="@+id/sf_guibuilder_clear_log_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_margin="10dp"
                    android:minWidth="0dp"

                    android:minHeight="0dp"
                    android:text="Clear Log"
                    android:textSize="13sp"
                    tools:ignore="TouchTargetSizeCheck" />
            </LinearLayout>
        </LinearLayout>
    </com.sifli.sifliapp.utils.SFScrollView>
</LinearLayout>